# Database
DATABASE_URL="mysql://user:password@localhost:3306/absensi_db"

# NextAuth
NEXTAUTH_SECRET="your-secret-here-change-in-production"
NEXTAUTH_URL="https://your-domain.com"

# Session encryption — optional, falls back to NEXTAUTH_SECRET if not set.
# 32-byte key: 64-char hex or base64 string.
# SESSION_TOKEN_ENCRYPTION_KEY=

# Session lifetime overrides (seconds) — defaults to 10 years.
# SESSION_MAX_AGE_SECONDS=315360000
# SESSION_UPDATE_AGE_SECONDS=43200

# Google Maps — reverse geocoding
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
